# PostgreSQL connection string. Easiest free options: Neon (neon.tech) or Supabase.
# Example (Neon): postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/classtrack?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/classtrack"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
